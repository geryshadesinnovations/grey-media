APP_NAME="Greyshades Media Platform"

APP_ENV=production
APP_DEBUG=true

APP_URL=https://dev.greyshadesinnovation.com

APP_KEY=greyshades-media-project-key

DB_HOST=localhost
DB_PORT=80
DB_NAME=greyshades_media
DB_USER=greyshades_user
DB_PASS=Greyshades@123

STORAGE_PATH=/var/www/greyshades-media/storage

UPLOAD_MAX_MB=2048

FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe
IMAGEMAGICK_BIN=/usr/bin/convert
LIBREOFFICE_BIN=/usr/bin/libreoffice

SESSION_LIFETIME_MIN=120
STREAM_TOKEN_TTL_MIN=15

ENABLE_WATERMARK=true
ENABLE_ANTI_INSPECT=true
